<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>App-Owns-Data Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="~/lib/bootstrap5/dist/css/bootstrap.min.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/lib/font-awesome6/css/all.min.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
  @{ var custName = _config["DemoSettings:CustomerName"] ?? "Customer"; }
  <header>
    <nav class="navbar navbar-expand navbar-dark admin-navbar">
      <div class="container-fluid admin-nav-inner">
        <a class="navbar-brand admin-brand" asp-area="" asp-controller="Home" asp-action="Index">
          <span class="brand-icon"><i class="fa-solid fa-bolt"></i></span>
          <span class="brand-text">@custName's Power BI <span class="brand-highlight">Command Center</span></span>
        </a>
        <div class="navbar-collapse">
          <ul class="navbar-nav admin-nav-links me-auto">
          </ul>
          <partial name="_LoginPartial" />
        </div>
      </div>
    </nav>
  </header>
  <div class="container admin-page-container">
    <main role="main" class="pb-4">
      @RenderBody()
    </main>
  </div>
  <script src="~/lib/bootstrap5/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
  @RenderSection("Scripts", required: false)
</body>
</html>
