@using System.Security.Principal

<ul class="navbar-nav admin-user-nav">
  @if (User.Identity.IsAuthenticated) {
    <li class="nav-item admin-user-item">
      <span class="admin-user-avatar"><i class="fa-solid fa-user-circle"></i></span>
      <span class="admin-user-name">@User.FindFirst("name").Value</span>
    </li>
    <li class="nav-item">
      <a class="nav-link admin-signout-link" asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignOut">
        <i class="fa-solid fa-right-from-bracket"></i> Sign out
      </a>
    </li>
  }
  else {
    <li class="nav-item">
      <a class="nav-link admin-signin-link" asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignIn">
        <i class="fa-solid fa-right-to-bracket"></i> Sign in
      </a>
    </li>
  }
</ul>