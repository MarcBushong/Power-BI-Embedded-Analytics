@model AppOwnsDataAdmin.Services.EmbeddedReportViewModel

@{
  var primary   = Model.ThemePrimary   ?? "#37474F";
  var secondary = Model.ThemeSecondary ?? "#546E7A";
  var tertiary  = Model.ThemeTertiary  ?? "#FF6F00";
  var logo      = Model.LogoSymbol     ?? "T";
  var tagline   = Model.Tagline        ?? "";
}

<style>
  body { background-color: @primary !important; }
  .admin-page-container { padding-top: 0.65rem; }
  h2.embed-heading { color: rgba(255,255,255,0.88) !important; text-shadow: 0 1px 4px rgba(0,0,0,0.35); }
  h2.embed-heading .h2-backarrow { color: rgba(255,255,255,0.8) !important; background: rgba(255,255,255,0.12) !important; border: 1px solid rgba(255,255,255,0.22) !important; }
  h2.embed-heading .h2-backarrow:hover { background: rgba(255,255,255,0.22) !important; }
  h2.embed-heading .fa-bar-chart { color: rgba(255,255,255,0.45) !important; }
</style>

<h2 class="embed-heading">
  <a class="btn btn-sm h2-backarrow" asp-action="Tenants" title="Back to @(_config["DemoSettings:CustomerName"] ?? "Customer")'s Customers"><i class="fa-solid fa-arrow-left"></i></a>
  <i class="fa-solid fa-chart-bar" style="font-size:1.1rem"></i>
  @Model.TenantName — Sales Report
</h2>

<div id="brand-banner">
  <div id="brand-logo-container"><div id="brand-logo"></div></div>
  <div id="brand-info">
    <div id="brand-company-name">@Model.TenantName</div>
    <div id="brand-tagline">@tagline</div>
  </div>
</div>

<div class="embed-layout">
  <div id="embed-sidebar">
    <div id="embed-sidebar-header">Reports</div>
    @if (Model.Reports != null) {
      foreach (var r in Model.Reports) {
        <a href="#" class="embed-report-link @(r.Id == Model.ReportId ? "active" : "")"
           data-report-id="@r.Id"
           data-embed-url="@r.EmbedUrl"
           data-report-type="@r.ReportType"
           data-token="@r.Token">
          <i class="fa-solid @(r.ReportType == "PaginatedReport" ? "fa-file-lines" : "fa-chart-bar")"></i>
          @r.Name
        </a>
      }
    }
  </div>
  <div id="report-container"></div>
</div>

@section Scripts {

  @* jQuery is required by the Power BI embed JavaScript on this page *@
  <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
  <script src="~/lib/powerbi-client/dist/powerbi.min.js" asp-append-version="true"></script>

  <script type="text/javascript">
    $(function() {

        // ── Branding ──────────────────────────────────────────────────────────
        var brand = {
            primary:   '@Html.Raw(primary)',
            secondary: '@Html.Raw(secondary)',
            tertiary:  '@Html.Raw(tertiary)',
            logo:      '@Html.Raw(logo)',
            tenant:    '@Html.Raw(Model.TenantName)'
        };

        function buildLogoSvg(sym) {
            sym = (sym || 'T').toUpperCase();
            var logos = {
                'WT': '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 44 44"><circle cx="22" cy="22" r="21" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1"/><path d="M5 18 C14 11 30 9 41 14 L37 21 C26 17 12 19 7 25 Z" fill="rgba(255,255,255,0.95)"/><path d="M7 25 C11 27 17 26 21 23 L19 30 C13 32 6 30 7 27 Z" fill="rgba(255,255,255,0.55)"/><line x1="22" y1="28" x2="22" y2="39" stroke="rgba(255,255,255,0.6)" stroke-width="2" stroke-linecap="round"/><circle cx="38" cy="10" r="2.5" fill="rgba(255,255,255,0.4)"/></svg>',
                'CO': '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 44 44"><circle cx="22" cy="22" r="21" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1"/><path d="M35 13 A17 17 0 1 0 35 31 L29 27 A10 10 0 1 1 29 17 Z" fill="rgba(255,255,255,0.95)"/><path d="M30 18 L37 14 L36 22 L30 26 Z" fill="rgba(255,255,255,0.35)"/><circle cx="22" cy="22" r="2.5" fill="rgba(255,255,255,0.25)"/></svg>',
                'MC': '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 44 44"><circle cx="22" cy="22" r="21" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1"/><rect x="5"  y="30" width="6"  height="9"  rx="1.5" fill="rgba(255,255,255,0.65)"/><rect x="13" y="22" width="6"  height="17" rx="1.5" fill="rgba(255,255,255,0.8)"/><rect x="21" y="13" width="6"  height="26" rx="1.5" fill="rgba(255,255,255,0.95)"/><rect x="29" y="19" width="6"  height="20" rx="1.5" fill="rgba(255,255,255,0.75)"/><line x1="24" y1="13" x2="24" y2="6" stroke="rgba(255,255,255,0.7)" stroke-width="1.5" stroke-linecap="round"/><circle cx="24" cy="5" r="2" fill="rgba(255,255,255,0.6)"/></svg>',
                'AC': '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 44 44"><circle cx="22" cy="22" r="21" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1"/><path d="M22 7 L34 36 L22 30 L10 36 Z" fill="none" stroke="rgba(255,255,255,0.95)" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/><line x1="15" y1="27" x2="29" y2="27" stroke="rgba(255,255,255,0.95)" stroke-width="2" stroke-linecap="round"/><circle cx="22" cy="17" r="2" fill="rgba(255,255,255,0.75)"/><circle cx="36" cy="11" r="3.5" fill="none" stroke="rgba(255,255,255,0.45)" stroke-width="1.5"/><circle cx="36" cy="11" r="1.2" fill="rgba(255,255,255,0.6)"/></svg>',
                'ROCKET': '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 44 44"><circle cx="22" cy="22" r="21" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1"/><path d="M16 14 Q22 3 28 14 Z" fill="rgba(255,255,255,0.95)"/><rect x="16" y="14" width="12" height="16" rx="2" fill="rgba(255,255,255,0.9)"/><circle cx="22" cy="19" r="3" fill="none" stroke="rgba(255,255,255,0.45)" stroke-width="1.5"/><path d="M16 24 L9 34 L16 30 Z" fill="rgba(255,255,255,0.72)"/><path d="M28 24 L35 34 L28 30 Z" fill="rgba(255,255,255,0.72)"/><path d="M16 30 L14 34 L30 34 L28 30 Z" fill="rgba(255,255,255,0.55)"/><path d="M14 34 C13 38 22 43 22 43 C22 43 31 38 30 34 Z" fill="rgba(255,255,255,0.85)"/><path d="M17 34 C16 37 22 40 22 40 C22 40 28 37 27 34 Z" fill="rgba(255,255,255,0.3)"/></svg>'
            };
            if (logos[sym]) return logos[sym];
            var fs = sym.length > 1 ? '13' : '17';
            return '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 44 44"><circle cx="22" cy="22" r="21" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/><circle cx="22" cy="22" r="17" fill="rgba(255,255,255,0.1)"/><text x="22" y="28" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-size="' + fs + '" font-weight="800" fill="white" letter-spacing="-0.5">' + sym + '</text></svg>';
        }

        // Apply theme CSS vars
        document.documentElement.style.setProperty('--theme-primary',   brand.primary);
        document.documentElement.style.setProperty('--theme-secondary', brand.secondary);
        document.documentElement.style.setProperty('--theme-tertiary',  brand.tertiary);

        // Render logo + banner gradient
        $('#brand-logo').html(buildLogoSvg(brand.logo));
        $('#brand-banner').css('background', 'linear-gradient(135deg,' + brand.primary + ' 0%,' + brand.secondary + ' 100%)');

        // ── Power BI Embed ────────────────────────────────────────────────────
        var models          = window["powerbi-client"].models;
        var reportContainer = $("#report-container").get(0);

        function getEmbedConfig(id, url, type, token) {
            var config = {
                type: "report",
                id: id,
                embedUrl: url,
                accessToken: token,
                tokenType: models.TokenType.Embed
            };
            if (type !== "PaginatedReport") {
                config.settings = {
                    panes: {
                        filters:        { visible: false, expanded: false },
                        pageNavigation: { visible: true, position: models.PageNavigationPosition.Left }
                    }
                };
            }
            return config;
        }

        function applyPbiTheme(rpt) {
            rpt.off("loaded");
            rpt.on("loaded", function() {
                var themeJson = {
                    name: brand.tenant + ' Theme',
                    dataColors: [brand.primary, brand.secondary, brand.tertiary,
                                 '#546E7A', '#90A4AE', '#FF8F00', '#00897B', '#5C6BC0', '#F06292'],
                    tableAccent: brand.primary,
                    foreground:  '#1e293b',
                    background:  '#ffffff',
                    visualStyles: {
                        page: { '*': { background: [{ properties: { color: { solid: { color: '#f8fafc' } } } }] } }
                    }
                };
                rpt.applyTheme({ themeJson: themeJson }).catch(function(e) {
                    console.warn('PBI theme apply failed:', e);
                });
            });
        }

        // Initial embed
        var initialType   = '@Html.Raw(Model.ReportType ?? "PowerBIReport")';
        var currentReport = powerbi.embed(reportContainer, getEmbedConfig("@Model.ReportId", "@Model.EmbedUrl", initialType, "@Model.Token"));
        if (initialType !== "PaginatedReport") { applyPbiTheme(currentReport); }

        currentReport.off("rendered");
        currentReport.on("rendered", function() { console.log("Report render successful"); });
        currentReport.off("error");
        currentReport.on("error", function(event) { console.error(event.detail); });

        // ── Report Switcher ───────────────────────────────────────────────────
        $(document).on('click', '.embed-report-link', function(e) {
            e.preventDefault();
            var id   = $(this).data('report-id');
            var url  = $(this).data('embed-url');
            var type = $(this).data('report-type');
            var token = $(this).data('token');
            powerbi.reset(reportContainer);
            currentReport = powerbi.embed(reportContainer, getEmbedConfig(id, url, type, token));
            if (type !== "PaginatedReport") { applyPbiTheme(currentReport); }
            currentReport.off("error");
            currentReport.on("error", function(event) { console.error(event.detail); });
            $('.embed-report-link').removeClass('active');
            $(this).addClass('active');
        });

    });
  </script>
}
